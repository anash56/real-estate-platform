generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  password          String
  fullName          String
  role              String   // BUYER, AGENT, ADMIN
  emailVerified     Boolean  @default(false)
  phoneVerified     Boolean  @default(false)
  phone             String?  @unique
  profilePhoto      String?
  governmentId      String?
  idVerified        Boolean  @default(false)
  emailOtp          String?
  emailOtpExpiry    DateTime?
  phoneOtp          String?
  phoneOtpExpiry    DateTime?
  resetPasswordOtp       String?
  resetPasswordOtpExpiry DateTime?
  
  properties        Property[] @relation("AgentProperties")
  inquiries         Inquiry[]
  toursRequested    TourRequest[] @relation("BuyerTours")
  reviews           Review[]
  messages          Message[]
  favorites         Favorite[]
  agreements        UserAgreement[]
  notifications     Notification[]
  savedSearches     SavedSearch[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([role])
}

model Property {
  id                String   @id @default(cuid())
  agentId           String
  agent             User     @relation("AgentProperties", fields: [agentId], references: [id])
  
  title             String
  description       String   @db.Text
  propertyType      String
  bedrooms          Int
  bathrooms         Int
  area              Float
  
  address           String
  city              String
  state             String
  pincode           String
  latitude          Float
  longitude         Float
  
  price             BigInt
  builtYear         Int?
  facing            String?
  amenities         String[]
  virtualTourUrl    String?
  
  status            String   @default("DRAFT")
  moderationStatus  String   @default("PENDING_REVIEW")
  
  viewCount         Int                 @default(0)
  riskScore         Int                 @default(0)
  flaggedReasons    String[]
  defectDisclosure  DefectDisclosure?
  legalDocuments    LegalDocument[]
  priceHistory      PriceHistory[]

  images            PropertyImage[]
  inquiries         Inquiry[]
  tourRequests      TourRequest[]
  reviews           Review[]
  favorites         Favorite[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([agentId])
  @@index([city])
  @@index([status])
}

model PropertyImage {
  id                String   @id @default(cuid())
  propertyId        String
  property          Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  imageUrl          String
  order             Int
  isMainImage       Boolean  @default(false)
  uploadedAt        DateTime @default(now())
  
  @@index([propertyId])
}

model SavedSearch {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  filters     Json
  createdAt   DateTime @default(now())
  @@index([userId])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title       String
  message     String   @db.Text
  type        String   @default("INFO")
  isRead      Boolean  @default(false)
  link        String?
  createdAt   DateTime @default(now())
  @@index([userId])
}

model Inquiry {
  id                String   @id @default(cuid())
  propertyId        String
  property          Property @relation(fields: [propertyId], references: [id])
  
  buyerId           String
  buyer             User     @relation(fields: [buyerId], references: [id])
  
  message           String
  budget            BigInt?
  status            String   @default("NEW")
  
  buyerEmailHidden  Boolean  @default(true)
  buyerPhoneHidden  Boolean  @default(true)
  
  createdAt         DateTime @default(now())
  agentResponse     String?  @db.Text
  respondedAt       DateTime?
  messages          Message[]
  
  @@index([propertyId])
  @@index([buyerId])
}

model Message {
  id          String   @id @default(cuid())
  inquiryId   String
  inquiry     Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  
  senderId    String
  sender      User     @relation(fields: [senderId], references: [id])
  
  content     String   @db.Text
  createdAt   DateTime @default(now())
  
  @@index([inquiryId])
  @@index([senderId])
}

model Review {
  id                String   @id @default(cuid())
  propertyId        String
  property          Property @relation(fields: [propertyId], references: [id])
  
  reviewerId        String
  reviewer          User     @relation(fields: [reviewerId], references: [id])
  
  rating            Int
  title             String
  description       String   @db.Text
  isVerified        Boolean  @default(false)
  isApproved        Boolean  @default(true)
  
  createdAt         DateTime @default(now())
  
  @@index([propertyId])
}

model Favorite {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  propertyId        String
  property          Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  addedAt           DateTime @default(now())
  
  @@unique([userId, propertyId])
}

model UserAgreement {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  agreementType     String
  accepted          Boolean  @default(false)
  acceptedAt        DateTime?
  
  createdAt         DateTime @default(now())
  
  @@index([userId])
}

model DefectDisclosure {
  id                          String   @id @default(cuid())
  propertyId                  String   @unique
  property                    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  hasStructuralIssues         Boolean
  structuralIssuesDetails     String?

  hasLegalDisputes            Boolean
  legalDisputesDetails        String?

  hasPreviousDamage           Boolean
  previousDamageDetails       String?

  hasEnvironmentalHazards     Boolean
  environmentalHazardsDetails String?

  agentSignedOff              Boolean  @default(false)

  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model LegalDocument {
  id           String   @id @default(cuid())
  propertyId   String
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  documentType String
  documentUrl  String
  isVerified   Boolean  @default(false)
  uploadedAt   DateTime @default(now())

  @@index([propertyId])
}

model TourRequest {
  id          String   @id @default(cuid())
  
  buyerId     String
  buyer       User     @relation("BuyerTours", fields: [buyerId], references: [id])
  
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  date        DateTime
  message     String?  @db.Text
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([buyerId])
  @@index([propertyId])
}

model PriceHistory {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  price       BigInt
  changedAt   DateTime @default(now())
  
  @@index([propertyId])
}